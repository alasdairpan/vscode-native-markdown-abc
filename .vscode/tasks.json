{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: watch",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "watch"
      ],
      "isBackground": true,
      "problemMatcher": [
        {
          "owner": "custom",
          "pattern": {
            "regexp": "^(?!)$"
          },
          "background": {
            "activeOnStart": true,
            "beginsPattern": "^\\[watch\\] build started$",
            "endsPattern": "^\\[watch\\] build finished$"
          }
        }
      ],
      "presentation": {
        "reveal": "never"
      }
    }
  ]
}